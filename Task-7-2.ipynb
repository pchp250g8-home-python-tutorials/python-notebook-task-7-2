   "source": [
    "Решить уравнение 1 / x + x + x ^ 2 + ... + x ^ n = 3, где |x| < 1."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1a03925d",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sympy import Eq\n",
    "from sympy import solve\n",
    "from sympy import symbols\n",
    "\n",
    "x = symbols(\"x\")\n",
    "b1 = x; q = x;\n",
    "S = b1 / (1 - q)\n",
    "eq1 = Eq(S + 1 / x, 3)\n",
    "print(eq1.lhs, \"=\", eq1.rhs)\n",
    "result = solve(eq1, x)\n",
    "print(result)\n"
   ]
  }
 ],
